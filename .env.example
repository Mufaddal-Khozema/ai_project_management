# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://auth_user:auth_pass@localhost:5432/auth_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_USER_CREATED=auth.user.created
KAFKA_TOPIC_LOGIN_SUCCESS=auth.user.login.success
KAFKA_TOPIC_LOGIN_FAILED=auth.user.login.failed
KAFKA_TOPIC_TOKEN_REFRESHED=auth.token.refreshed

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ─── Default Roles ────────────────────────────────────────────────────────────
DEFAULT_ROLE=user
